{
  "name": "@framework/core",
  "version": "0.0.0",
  "description": "VitePress-style documentation meta-framework: routing, layout, search, theme, and the markdown pipeline, packaged for reuse.",
  "bin": {
    "framework-ssg": "./scripts/build.js"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./vite": "./src/defineConfig.ts",
    "./ssg": "./src/ssg.ts",
    "./sitemap": "./src/sitemap.ts",
    "./App.vue": "./src/App.vue",
    "./styles/entry.css": "./src/styles/entry.css",
    "./styles/framework.css": "./src/styles/framework.css",
    "./client": "./shims.d.ts",
    "./tsconfig.base.json": "./tsconfig.base.json"
  },
  "dependencies": {
    "@heroicons/vue": "catalog:",
    "@unhead/dom": "catalog:",
    "@vue/server-renderer": "catalog:",
    "fuzzysort": "catalog:",
    "jsdom": "catalog:",
    "markdown-it": "catalog:",
    "markdown-it-anchor": "catalog:",
    "markdown-it-container": "catalog:",
    "reka-ui": "catalog:",
    "unplugin-vue-markdown": "catalog:"
  },
  "devDependencies": {
    "@types/jsdom": "catalog:",
    "@types/markdown-it": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/test-utils": "catalog:",
    "@vue/tsconfig": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@tailwindcss/typography": "^0.5",
    "@tailwindcss/vite": "^4",
    "@unhead/vue": "^2",
    "@vitejs/plugin-vue": "^6",
    "mermaid": "^11",
    "tailwindcss": "^4",
    "vite": ">=6.0.0",
    "vue": "^3.5",
    "vue-router": "~5.0.7"
  },
  "peerDependenciesMeta": {
    "mermaid": {
      "optional": true
    }
  }
}
