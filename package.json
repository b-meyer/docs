{
  "name": "docs-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:tcm": "vp run tcm#dev",
    "dev:8fold": "vp run 8fold#dev",
    "dev:showcase": "vp run showcase#dev",
    "preview:tcm": "vp run tcm#preview",
    "preview:8fold": "vp run 8fold#preview",
    "preview:showcase": "vp run showcase#preview",
    "build": "vp run -r build",
